{
  "compilerOptions": {
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@atlas/web/*": ["./apps/web/*"],
      "@atlas/api/*": ["./apps/api/*"],
      "@atlas/shared/*": ["./packages/shared/*"]
    }
  },
  "exclude": ["node_modules"]
}
